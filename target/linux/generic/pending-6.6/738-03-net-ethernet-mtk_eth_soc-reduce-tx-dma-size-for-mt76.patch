From d57daf04d29a925b43e56db81dcfed20ddd1c300 Mon Sep 17 00:00:00 2001
From: Kroks <dev@kroks.ru>
Date: Wed, 17 Sep 2025 12:45:44 +0300
Subject: [PATCH] net: ethernet: mtk_eth_soc: reduce tx dma size for mt7621

---
 drivers/net/ethernet/mediatek/mtk_eth_soc.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
@@ -5432,7 +5432,7 @@ static const struct mtk_soc_data mt7621_
 		.desc_size = sizeof(struct mtk_tx_dma),
 		.dma_max_len = MTK_TX_DMA_BUF_LEN,
 		.dma_len_offset = 16,
-		.dma_size = MTK_DMA_SIZE(2K),
+		.dma_size = MTK_DMA_SIZE(512),
 		.fq_dma_size = MTK_DMA_SIZE(2K),
 	},
 	.rx = {
