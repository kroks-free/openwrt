From ac8ca88a5749f4efcdd9e188d81e4c09e3a85f37 Mon Sep 17 00:00:00 2001
From: Kroks <dev@kroks.ru>
Date: Sat, 1 Nov 2025 19:52:22 +0300
Subject: [PATCH] mtd: parsers: implement dynamic mtd partitions

---
 drivers/mtd/parsers/ofpart_core.c | 27 ++++++++++++++++++++++++---
 1 file changed, 24 insertions(+), 3 deletions(-)

--- a/drivers/mtd/parsers/ofpart_core.c
+++ b/drivers/mtd/parsers/ofpart_core.c
@@ -103,6 +103,8 @@ static int parse_fixed_partitions(struct
 		const __be32 *reg;
 		int len;
 		int a_cells, s_cells;
+		bool dynamic_end, tail_partition;
+		u64 reg_offset, reg_size, part_offset, part_size;
 
 		if (!dedicated && node_has_compatible(pp))
 			continue;
@@ -148,15 +150,32 @@ static int parse_fixed_partitions(struct
 			goto ofpart_fail;
 		}
 
-		parts[i].offset = of_read_number(reg, a_cells);
-		parts[i].size = of_read_number(reg + a_cells, s_cells);
-		parts[i].of_node = pp;
+		dynamic_end = of_get_property(pp, "dynamic-end", &len);
+		tail_partition = of_get_property(pp, "tail-partition", &len);
+
+		reg_offset = of_read_number(reg, a_cells);
+		reg_size = of_read_number(reg + a_cells, s_cells);
 
 		partname = of_get_property(pp, "label", &len);
 		if (!partname)
 			partname = of_get_property(pp, "name", &len);
 		parts[i].name = partname;
 
+		if (tail_partition) {
+			part_offset = master->size - reg_offset;
+			part_size = reg_size;
+		} else if (dynamic_end) {
+			part_offset = reg_offset;
+			part_size = master->size - reg_offset - reg_size;
+		} else {
+			part_offset = reg_offset;
+			part_size = reg_size;
+		}
+
+		parts[i].offset = part_offset;
+		parts[i].size = part_size;
+		parts[i].of_node = pp;
+
 		if (of_get_property(pp, "read-only", &len))
 			parts[i].mask_flags |= MTD_WRITEABLE;
 
@@ -191,6 +210,8 @@ ofpart_none:
 static const struct of_device_id parse_ofpart_match_table[] = {
 	/* Generic */
 	{ .compatible = "fixed-partitions" },
+	/* Kroks */
+	{ .compatible = "dynamic-partitions" },
 	/* Customized */
 	{ .compatible = "brcm,bcm4908-partitions", .data = &bcm4908_partitions_quirks, },
 	{ .compatible = "linksys,ns-partitions", .data = &linksys_ns_partitions_quirks, },
