#include "mt7628an_kroks_4eth.dtsi"

#include <dt-bindings/leds/common.h>

/ {
	compatible = "kroks,kndrt31r20", "mediatek,mt7628an-soc";
	model = "Kroks KNdRt31R20";

	aliases {
		led-boot = &led_status;
		led-failsafe = &led_status;
		led-running = &led_status;
		led-upgrade = &led_status;
	};

	gpio-leds {
		compatible = "gpio-leds";

		led_status: led-0 {
			color = <LED_COLOR_ID_WHITE>;
			gpios = <&gpio 2 GPIO_ACTIVE_LOW>;
			function = LED_FUNCTION_STATUS;
		};

		led-1 {
			color = <LED_COLOR_ID_WHITE>;
			gpios = <&gpio 44 GPIO_ACTIVE_LOW>;
			function = LED_FUNCTION_WLAN;
			linux,default-trigger = "phy0tpt";
		};
	};

	gpio_export {
		compatible = "gpio-export";
		#size-cells = <0>;

		modem1power {
			gpio-export,name = "modem1power";
			gpio-export,output = <1>;
			gpios = <&gpio 1 GPIO_ACTIVE_HIGH>;
		};

		modem1sim1 {
			gpio-export,name = "modem1sim1";
			gpio-export,output = <1>;
			gpios = <&gpio 3 GPIO_ACTIVE_HIGH>;
		};

		modem1sim2 {
			gpio-export,name = "modem1sim2";
			gpio-export,output = <0>;
			gpios = <&gpio 4 GPIO_ACTIVE_HIGH>;
		};

		/* deprecated */
		gpio11 {
			gpio-export,name = "gpio11";
			gpios = <&gpio 11 GPIO_ACTIVE_HIGH>;
		};

		/* deprecated */
		gpio37 {
			gpio-export,name = "gpio37";
			gpio-export,output = <0>;
			gpios = <&gpio 37 GPIO_ACTIVE_HIGH>;
		};
	};
};

&state_default {
	gpio {
		groups = "i2s", "i2c", "wled_an";
		function = "gpio";
	};

	/* deprecated */
	gpio_kdevice {
		groups = "gpio", "refclk";
		function = "gpio";
	};
};
