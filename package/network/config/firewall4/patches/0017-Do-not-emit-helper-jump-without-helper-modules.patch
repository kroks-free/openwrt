From fb1172243ce8af8fb44e1df5ab9796efa57545f8 Mon Sep 17 00:00:00 2001
From: Andris PE <neandris@gmail.com>
Date: Fri, 22 Mar 2024 10:51:07 +0000
Subject: [PATCH 17/18] Do not emit helper jump without helper modules

Do not emit helper jump if no helper modules are present saving
per-every-packet bytecode before ct:
```
inet fw4 prerouting
  [ meta load iifname => reg 1 ]
  [ cmp eq reg 1 0x6c2d7262 0x00006e61 0x00000000 0x00000000 ]
  [ immediate reg 0 jump -> helper_lan ]
  userdata = { \x00-!fw4: Handle lan IPv4/IPv6 helper assignment\x00 }
```

Signed-off-by: Andris PE <neandris@gmail.com>
---
 root/usr/share/ucode/fw4.uc           |  3 ++-
 tests/02_zones/01_policies            | 12 ------------
 tests/02_zones/04_wildcard_devices    | 23 -----------------------
 tests/02_zones/05_subnet_mask_matches |  9 ---------
 tests/03_rules/03_constraints         |  3 ---
 tests/03_rules/05_mangle              |  8 --------
 tests/03_rules/11_log                 |  3 ---
 7 files changed, 2 insertions(+), 59 deletions(-)

--- a/root/usr/share/ucode/fw4.uc
+++ b/root/usr/share/ucode/fw4.uc
@@ -2209,7 +2209,7 @@ return {
 			zone.dflags.snat = true;
 
 		if ((zone.auto_helper && !(zone.masq || zone.masq6)) || length(zone.helper)) {
-			zone.dflags.helper = true;
+			zone.dflags.helper = false;
 
 			for (let helper in (length(zone.helper) ? zone.helper : this.state.helpers)) {
 				if (!helper.available)
@@ -2226,6 +2226,7 @@ return {
 						target: "helper",
 						set_helper: helper
 					});
+					zone.dflags.helper = true;
 				}
 			}
 		}
